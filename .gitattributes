# Normalize line endings: LF in the repo, so Linux CI (GitHub Actions, v0.6.0)
# and Windows dev agree. Silences the "LF will be replaced by CRLF" warnings.
* text=auto eol=lf

# Explicit text types
*.tf     text eol=lf
*.py     text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.hcl    text eol=lf
Dockerfile text eol=lf

# Binaries (never normalize)
*.png  binary
*.jpg  binary
*.zip  binary
*.gz   binary
*.docx binary
*.pdf  binary
