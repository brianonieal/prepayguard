*.py[cod]
.pytest_cache/
.venv/
venv/
.ruff_cache/
*.egg-info/

# Scan output (regenerated; final copies for the handoff package are curated
# into docs/ at v1.0.0, not committed from here)
checkov-report*
tflint-report*
pip-audit-report*
grype-report*

# Local secrets (never committed). SAM.gov API key for scripts/ingest_sam_exclusions.py
